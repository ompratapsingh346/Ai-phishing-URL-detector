{
  "manifest_version": 3,

  "name": "AI Phishing Detector",

  "version": "1.0",

  "description": "Detect phishing websites using AI",

  "permissions": [
    "tabs",
    "activeTab"
  ],

  "host_permissions": [
    "http://localhost:8080/*"
  ],

  "action": {

    "default_popup": "popup.html"
  }
}